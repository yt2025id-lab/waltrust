# Tatum API Key — get from https://dashboard.tatum.io
TATUM_API_KEY=your_tatum_api_key_here

# SUI Smart Contract (after deploy)
NEXT_PUBLIC_PACKAGE_ID=0x_your_package_id_here
NEXT_PUBLIC_NETWORK=mainnet

# Walrus endpoints (defaults to mainnet)
NEXT_PUBLIC_WALRUS_PUBLISHER=https://publisher.walrus-mainnet.walrus.space
NEXT_PUBLIC_WALRUS_AGGREGATOR=https://aggregator.walrus-mainnet.walrus.space
